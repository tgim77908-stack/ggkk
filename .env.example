# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_API_URL: Vercel/Client API URL pointing to the hosted backend server (e.g., https://my-backend.onrender.com)
VITE_API_URL=""

# VITE_WS_URL: Vercel/Client WebSocket URL pointing to the hosted backend server (e.g., wss://my-backend.onrender.com)
VITE_WS_URL=""
